# Venice AI API Key — required for all proxied requests (chat, image, upscale).
# Sign up at https://venice.ai and copy your key from the API settings page.
VENICE_API_KEY=your_venice_api_key_here

# Optional password to restrict access. Leave blank for public access.
DEPLOYMENT_PASSWORD=

# Restrict CORS to a specific origin (defaults to "*" if unset).
ALLOWED_ORIGIN=http://localhost:3000

# Rate limits per IP per hour. Defaults: chat=20, image=5, upscale=5.
# RATE_LIMIT_CHAT=20
# RATE_LIMIT_IMAGE=5
# RATE_LIMIT_UPSCALE=5
